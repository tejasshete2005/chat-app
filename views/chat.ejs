<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover" />
  <title>ChatWave — General</title>
  <link rel="stylesheet" href="/css/style.css" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet" />
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" />
</head>
<body>

<!-- Lightbox for images -->
<div class="lightbox" id="lightbox">
  <div class="lightbox-close" id="lightboxClose"><i class="fa-solid fa-xmark"></i></div>
  <img src="" alt="Full size image" id="lightboxImg" />
</div>

<!-- Toast container -->
<div class="toast-container" id="toastContainer"></div>

<!-- Hidden file input -->
<input type="file" id="fileInput" accept="image/*,video/mp4,.pdf,.doc,.docx,.txt,.zip,.rar" />

<div class="chat-app" id="chat-app">

  <!-- ===== SIDEBAR ===== -->
  <aside class="sidebar" id="sidebar">
    <div class="sidebar-header">
      <div class="sidebar-top-row">
        <div class="sidebar-logo">
          <div class="logo-icon">💬</div>
          <span class="logo-text">ChatWave</span>
        </div>
        <a href="/profile" class="profile-icon-btn" title="My Profile">
          <i class="fa-solid fa-user-gear"></i>
        </a>
      </div>

      <!-- Current user card -->
      <div class="current-user-card">
        <div class="avatar" id="sidebar-avatar">
          <% if (currentUser.avatar) { %>
            <img src="<%= currentUser.avatar %>" alt="Avatar" />
          <% } else { %>
            <% const initials = currentUser.username.charAt(0).toUpperCase(); %>
            <%= initials %>
          <% } %>
          <div class="online-dot"></div>
        </div>
        <div class="current-user-info">
          <div class="name text-truncate" id="sidebar-name"><%= currentUser.username %></div>
          <div class="status">Online</div>
        </div>
      </div>
    </div>

    <!-- Sidebar Navigation Tabs -->
    <div class="sidebar-tabs">
      <button class="tab-btn active" id="tab-chats">Chats</button>
      <button class="tab-btn" id="tab-users">Users <span class="count" id="onlineCount">0</span></button>
    </div>

    <!-- Active Chats section -->
    <div class="sidebar-section" id="chats-section">
       <button id="create-group-btn" class="btn-primary" style="margin: 0 16px 16px; width: calc(100% - 32px); padding: 8px; font-size: 13px;">+ Create Group</button>
      <ul id="activeChatsList">
        <!-- Populated via JS -->
      </ul>
    </div>

    <!-- Online users / All users section -->
    <div class="sidebar-section hidden" id="users-section">
        <b style="margin: 0 16px 16px; width: calc(100% - 32px); padding: 8px; font-size: 13px;">All Users</b>
      <ul id="onlineUsersList">
        <!-- We will populate all users here -->
      </ul>
    </div>

    <!-- Sidebar Footer Removed -->
  </aside>

  <!-- ===== MAIN CHAT ===== -->
  <main class="chat-main">

    <!-- Header -->
    <div class="chat-header">
      <div class="chat-header-left">
        <button id="back-btn" class="back-btn">
          <i class="fa-solid fa-arrow-left"></i>
        </button>
        <div class="room-icon" id="header-avatar">
          <i class="fa-solid fa-comments"></i>
        </div>
        <div>
          <div class="room-name" id="header-name">Select a chat</div>
          <div class="room-info" id="memberCount"></div>
        </div>
      </div>
      <div class="chat-header-right">
        <div class="icon-btn hidden" id="group-settings-btn" title="Group Settings">
          <i class="fa-solid fa-gear"></i>
        </div>
      </div>
    </div>

    <!-- Messages -->
    <div id="messages-container">
      <div class="empty-state" id="initial-empty-state">
        <i class="fa-regular fa-comments"></i>
        <h3>Welcome to ChatWave</h3>
        <p>Select a user or group from the sidebar to start messaging.</p>
      </div>
    </div>

    <!-- Typing indicator -->
    <div id="typing-indicator"></div>

    <!-- Input Area -->
    <div class="chat-input-area">

      <!-- File upload preview -->
      <div class="upload-preview" id="uploadPreview">
        <i class="fa-solid fa-paperclip" style="color: var(--accent);"></i>
        <span class="upload-preview-name" id="uploadFileName"></span>
        <i class="fa-solid fa-xmark remove-file" id="removeFile"></i>
      </div>

      <!-- Upload progress -->
      <div class="upload-progress" id="uploadProgress">
        <i class="fa-solid fa-arrow-up-from-bracket" style="color: var(--accent);"></i>
        <div class="progress-bar-wrap">
          <div class="progress-bar" id="progressBar"></div>
        </div>
        <span id="progressText">0%</span>
      </div>

      <div class="input-row">
        <label class="attach-btn" for="fileInput" title="Attach file">
          <i class="fa-solid fa-paperclip"></i>
        </label>

        <textarea
          id="messageInput"
          placeholder="Message #general..."
          rows="1"
          autocomplete="off"
        ></textarea>

        <button class="send-btn" id="sendBtn" title="Send message">
          <i class="fa-solid fa-paper-plane"></i>
        </button>
      </div>
    </div>

  </main>
</div>

<!-- Group Creation Modal -->
<div id="group-modal" class="modal hidden">
  <div class="modal-content auth-card">
    <div class="modal-header">
      <h3>Create Group Chat</h3>
      <i class="fa-solid fa-xmark close-modal" onclick="closeGroupModal()"></i>
    </div>
    <div class="form-group">
      <input type="text" id="group-name-input" placeholder="Group Name" />
    </div>
    <p class="subtitle" style="text-align: left; margin-bottom: 8px;">Select Users:</p>
    <div class="user-selection-list" id="group-user-list">
      <!-- Users will render here -->
    </div>
    <button class="btn-primary" onclick="submitCreateGroup()">Create Group</button>
  </div>
</div>

<!-- Group Management Modal -->
<div id="group-manage-modal" class="modal hidden">
  <div class="modal-content auth-card">
    <div class="modal-header">
      <h3 id="manage-group-name">Manage Group</h3>
      <i class="fa-solid fa-xmark close-modal" onclick="closeManageGroupModal()"></i>
    </div>
    
    <div class="manage-section">
      <p class="subtitle" style="text-align: left; margin-top: 10px;">Members</p>
      <ul id="manage-members-list" class="user-selection-list"></ul>
    </div>

    <!-- Only visible to admin: Add member -->
    <div id="admin-add-section" class="manage-section hidden">
      <p class="subtitle" style="text-align: left; margin-top: 10px;">Add New Members</p>
      <div class="input-row">
        <select id="add-member-select" style="flex:1; padding: 8px; border-radius:4px; background:var(--bg-tertiary); color:white; border: 1px solid var(--border);">
          <option value="">Select a user...</option>
        </select>
        <button class="btn-primary" style="width: auto; padding: 8px 16px; margin-top:0;" onclick="adminAddMember()">Add</button>
      </div>
    </div>
    
    <button class="btn-primary" style="background: var(--danger); margin-top: 16px;" onclick="leaveGroup()">Leave Group</button>
  </div>
</div>

<!-- Message Delete Modal -->
<div id="delete-msg-modal" class="modal hidden">
  <div class="delete-modal-content">
    <h3 style="margin-bottom: 12px;">Delete message?</h3>
    <p class="subtitle" id="delete-msg-text">Are you sure you want to delete this message?</p>
    <div class="delete-modal-actions">
      <button class="delete-modal-btn everyone hidden" id="delete-everyone-btn">Delete for everyone</button>
      <button class="delete-modal-btn me" id="delete-me-btn">Delete for me</button>
      <button class="delete-modal-btn cancel" onclick="closeDeleteModal()">Cancel</button>
    </div>
  </div>
</div>

<!-- Incoming Call Popup -->
<div id="incoming-call-popup" class="call-popup hidden">
  <div class="call-popup-inner">
    <div class="caller-avatar" id="caller-avatar"></div>
    <div class="caller-info">
      <h4 id="caller-name">Caller Name</h4>
      <p id="call-type-text">Incoming Video Call...</p>
    </div>
    <div class="call-actions">
      <button class="call-btn accept" id="accept-call-btn" title="Accept"><i class="fa-solid fa-phone"></i></button>
      <button class="call-btn reject" id="reject-call-btn" title="Reject"><i class="fa-solid fa-phone-slash"></i></button>
    </div>
  </div>
</div>

<!-- Video Call Overlay -->
<div id="video-call-overlay" class="video-overlay hidden">
  <div class="video-container">
    <video id="remote-video" autoplay playsinline></video>
    <video id="local-video" autoplay playsinline muted></video>
    
    <div class="call-controls">
      <div class="call-status" id="call-status">Calling...</div>
      <button class="call-control-btn" id="toggle-video-btn" title="Toggle Video"><i class="fa-solid fa-video"></i></button>
      <button class="call-control-btn" id="toggle-mic-btn" title="Toggle Microphone"><i class="fa-solid fa-microphone"></i></button>
      <button class="call-control-btn end-call" id="end-call-btn" title="End Call"><i class="fa-solid fa-phone-slash"></i></button>
    </div>
  </div>
</div>

<!-- Pass server data to JS -->
<script>
window.CHAT_CONFIG = {
  currentUser: JSON.parse('<%- JSON.stringify(currentUser || null) %>'),
  allUsers: JSON.parse('<%- JSON.stringify(allUsers || []) %>')
};
</script>

<script src="/socket.io/socket.io.js"></script>
<script src="/js/chat.js"></script>

</body>
</html>